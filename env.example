# Vidya LLM configuration
# Copy this file to .env and fill in your values.
# load_dotenv() picks it up automatically from the project root.

# --- Primary model ---
# litellm model string. Prefix determines routing:
#   openai/   → local OpenAI-compatible endpoint (uses VIDYA_EVOLVE_API_BASE/KEY)
#   openrouter/  → OpenRouter (uses OPENROUTER_API_KEY)
#   anthropic/   → Anthropic API directly
# Default: openai/gemma-4-26b-a4b-it-4bit  (local Mac Mini)
# OpenRouter example: openrouter/openai/gpt-oss-120b
VIDYA_EVOLVE_MODEL=openai/gemma-4-26b-a4b-it-4bit

# --- Local OpenAI-compatible endpoint (only used when model starts with openai/) ---
VIDYA_EVOLVE_API_BASE=http://192.168.1.17:8099/v1
VIDYA_EVOLVE_API_KEY=omlx-1234

# --- Fallback model (used when primary is unreachable) ---
# Default: openrouter/google/gemma-4-26b-a4b-it
VIDYA_EVOLVE_FALLBACK_MODEL=openrouter/google/gemma-4-26b-a4b-it

# --- Timeouts (seconds) ---
VIDYA_EVOLVE_TIMEOUT=15
VIDYA_EVOLVE_FALLBACK_TIMEOUT=60

# --- Provider API keys ---
# Required if any model uses openrouter/ prefix
OPENROUTER_API_KEY=sk-or-...
